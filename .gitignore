# NOTE: keep comments on their OWN lines. An inline "#" in .gitignore is NOT a
# comment — it becomes part of the pattern and silently breaks the rule.

# secrets + real configs (never commit)
.env
!.env.example
assistant/config.json

# Frigate real config + sqlite db + generated runtime state (the whole dir)
nvr/config/
# legacy single-file path — keep ignored so a stray one can't be staged
nvr/config.yml
# but ship the example
!nvr/config.example.yml

# local data
nvr/storage/
**/*.jsonl
.sovereign-home/

# python
__pycache__/
*.pyc

# macOS / archive cruft
.DS_Store
._*
__MACOSX/
