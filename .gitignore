# secrets + real configs (never commit)
.env
!.env.example          # must ship — overrides a global .env.* ignore rule
assistant/config.json
nvr/config/            # real Frigate config + sqlite db + generated state
nvr/config.yml         # legacy single-file path — keep ignored so a stray one can't be staged
!nvr/config.example.yml  # example ships tracked

# local data
nvr/storage/
**/*.jsonl
.sovereign-home/

# python
__pycache__/
*.pyc

# macOS / archive cruft (so a folder-zip never ships these)
.DS_Store
._*
__MACOSX/
