# --- Camera credentials -----------------------------------------------------
# Tapo: open the Tapo app -> camera -> Advanced Settings -> Camera Account,
# create a username/password, then enable RTSP. Use that password here.
#
# IMPORTANT: use only letters and digits. Frigate does NOT URL-encode this, so
# special characters (@ : / # ? % &) will break the camera stream.
FRIGATE_RTSP_PASSWORD=change-me

# (The assistant's model is set in assistant/config.json, not here.)

# --- Optional assistant / compose settings ---------------------------------
# Used by the top-level docker-compose.yml. Leave Telegram blank unless you want
# phone delivery through Telegram.
SOVEREIGN_HOME_MODEL=qwen2.5:7b
SOVEREIGN_HOME_OLLAMA_URL=http://host.docker.internal:11434
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
FRIGATE_API_KEY=
